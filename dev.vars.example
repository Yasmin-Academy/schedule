# Local-only environment variables for `wrangler dev`.
# Copy to `dev.vars` and edit. DO NOT COMMIT `dev.vars`.

# Comma-separated list of allowed origins for the public widget APIs.
# Example: WIDGET_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
WIDGET_ALLOWED_ORIGINS=http://localhost:5174

# (Optional) These can be set for CalDAV availability blocking.
# CALDAV_CALENDAR_URL=
# CALDAV_USERNAME=
# CALDAV_PASSWORD=
