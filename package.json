{
  "name": "scheduler",
  "version": "1.0.0",
  "description": "Consultation scheduling platform built for Yasmin Academy bookings.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "npm run db:init && npm run build && wrangler dev --local",
    "dev:watch": "svelte-kit dev",
    "build": "npm run build:widget && vite build",
    "preview": "vite preview",
    "db:init": "node scripts/db-init.mjs --local",
    "db:init:remote": "node scripts/db-init.mjs --remote",
    "deploy": "npm run build && wrangler deploy",
    "prebuild": "node scripts/prebuild.js",
    "build:widget": "svelte-kit sync && vite build --config vite.widget.config.ts",
    "postinstall": "svelte-kit sync"
  },
  "author": "Yasmin Academy",
  "license": "UNLICENSED",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250927.0",
    "@sveltejs/adapter-cloudflare": "^7.2.3",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/validator": "^13.15.10",
    "svelte": "^5.39.6",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "wrangler": "^4.60.0"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.21",
    "isomorphic-dompurify": "^2.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "validator": "^13.15.23",
    "ical.js": "^1.5.0"
  }
}